---
/**
 * Counter-rotating scroll reel + per-character text rise, ported to
 * vanilla Astro/JS (no React) to match the rest of the site.
 *
 * testimonials: { quote: string, author: string, role?: string, image?: string, alt?: string }[]
 */
const { testimonials = [], charStaggerMs = 6, class: className = '' } = Astro.props;

const CELL = 121.33;
const GAP = 8;
const STEP = 3 * (CELL + GAP);
const count = testimonials.length;
const centerIdx = (count - 1) / 2;
const sideCellCount = 4 + 2 * count;

const middleItems = [];
for (let i = 0; i < 3; i++) middleItems.push({ type: 'cell' });
testimonials.forEach((_, i) => {
  middleItems.push({ type: 'featured', i });
  if (i < count - 1) middleItems.push({ type: 'cell' }, { type: 'cell' });
});
for (let i = 0; i < 3; i++) middleItems.push({ type: 'cell' });

const initialMiddleY = centerIdx * STEP;
const initialSideY = -initialMiddleY;

const first = testimonials[0] ?? { quote: '', author: '', role: '' };

function initials(name) {
  return (name || '?').trim().charAt(0).toUpperCase();
}

const dataJson = JSON.stringify(testimonials).replace(/</g, '\\u003c');
---

<div
  data-scroll-reel
  data-stagger={charStaggerMs}
  data-cell={CELL}
  data-gap={GAP}
  data-count={count}
  role="region"
  aria-roledescription="carousel"
  aria-label="Témoignages"
  tabindex="0"
  class={`relative mx-auto flex w-full max-w-[1060px] flex-col items-stretch gap-2.5 overflow-hidden rounded-2xl border border-navy/10 bg-white shadow-[inset_0_2px_0_rgba(255,255,255,1)] outline-none focus-visible:ring-2 focus-visible:ring-cyan md:min-h-[320px] md:flex-row ${className}`}
>
  <div
    aria-hidden="true"
    class="relative h-56 w-full shrink-0 self-stretch overflow-hidden md:h-auto md:w-[380px]"
    style="-webkit-mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%), linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%); mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%), linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%); -webkit-mask-composite: source-in; mask-composite: intersect;"
  >
    <div class="absolute inset-0 flex items-center justify-center gap-2">
      <div data-col="left" class="flex shrink-0 flex-col gap-2 will-change-transform" style={`transform: translateY(${initialSideY}px)`}>
        {Array.from({ length: sideCellCount }).map(() => (
          <div class="shrink-0 rounded-xl border border-navy/10 bg-gradient-to-b from-cream to-white blur-[1px] shadow-[0_1px_2px_rgba(0,0,0,0.05),inset_0_2px_0_rgba(255,255,255,1)]" style={`width:${CELL}px;height:${CELL}px`} />
        ))}
      </div>

      <div data-col="middle" class="flex shrink-0 flex-col gap-2 will-change-transform" style={`transform: translateY(${initialMiddleY}px)`}>
        {middleItems.map((item) =>
          item.type === 'featured' ? (
            (() => {
              const t = testimonials[item.i];
              return (
                <div
                  class="relative shrink-0 overflow-hidden rounded-xl bg-navy"
                  style={`width:${CELL}px;height:${CELL}px;box-shadow:0 1.008px 0.705px -0.563px rgba(0,0,0,0.18), 0 2.389px 1.672px -1.125px rgba(0,0,0,0.17), 0 4.357px 3.05px -1.688px rgba(0,0,0,0.17), 0 7.244px 5.07px -2.25px rgba(0,0,0,0.16), 0 11.698px 8.188px -2.813px rgba(0,0,0,0.15), 0 19.148px 13.404px -3.375px rgba(0,0,0,0.13), 0 32.972px 23.08px -3.938px rgba(0,0,0,0.09), 0 60px 42px -4.5px rgba(0,0,0,0.02), inset 0 1px 0 rgba(255,255,255,0.7), inset 0 -1px 0 rgba(0,0,0,0.6)`}
                >
                  {t.image ? (
                    <img src={t.image} alt={t.alt ?? ''} loading="lazy" class="absolute inset-0 h-full w-full object-cover object-[center_25%]" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-navy to-cyan text-3xl font-bold text-white">
                      {initials(t.author)}
                    </div>
                  )}
                  <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-[2] bg-white mix-blend-saturation" />
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-0 z-[3] blur-[6px] mix-blend-overlay"
                    style="background: linear-gradient(220.99deg, rgba(61,169,224,0) 32%, rgb(61,169,224) 41%, rgb(173,213,255) 47%, rgba(10,42,107,0.5) 54%, rgba(10,42,107,0) 65%);"
                  />
                </div>
              );
            })()
          ) : (
            <div class="shrink-0 rounded-xl border border-navy/10 bg-gradient-to-b from-cream to-white blur-[1px] shadow-[0_1px_2px_rgba(0,0,0,0.05),inset_0_2px_0_rgba(255,255,255,1)]" style={`width:${CELL}px;height:${CELL}px`} />
          )
        )}
      </div>

      <div data-col="right" class="flex shrink-0 flex-col gap-2 will-change-transform" style={`transform: translateY(${initialSideY}px)`}>
        {Array.from({ length: sideCellCount }).map(() => (
          <div class="shrink-0 rounded-xl border border-navy/10 bg-gradient-to-b from-cream to-white blur-[1px] shadow-[0_1px_2px_rgba(0,0,0,0.05),inset_0_2px_0_rgba(255,255,255,1)]" style={`width:${CELL}px;height:${CELL}px`} />
        ))}
      </div>
    </div>
  </div>

  <div class="flex min-w-0 flex-1 flex-col justify-between self-stretch px-5 py-7 md:py-10">
    <div class="flex flex-col gap-[9px]">
      <svg class="block h-12 w-12 text-navy/20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M4.58 17.32C3.55 16.23 3 15 3 13.01c0-3.5 2.46-6.64 6.03-8.19l.9 1.38c-3.34 1.8-4 4.15-4.25 5.62.54-.28 1.24-.38 1.93-.31 1.8.17 3.23 1.65 3.23 3.49a3.5 3.5 0 0 1-3.5 3.5c-1.07 0-2.1-.49-2.75-1.18zm10 0C13.55 16.23 13 15 13 13.01c0-3.5 2.46-6.64 6.03-8.19l.9 1.38c-3.34 1.8-4 4.15-4.25 5.62.54-.28 1.24-.38 1.93-.31 1.8.17 3.23 1.65 3.23 3.49a3.5 3.5 0 0 1-3.5 3.5c-1.07 0-2.1-.49-2.75-1.18z" />
      </svg>

      <div class="relative w-full max-w-[390px] overflow-hidden" aria-live="polite">
        <div aria-hidden="true" data-sizer class="invisible flex min-h-[140px] flex-col gap-[19px]">
          <p class="m-0 text-lg font-medium leading-[1.3] tracking-[-0.02em] text-navy sm:text-[22px]" data-sizer-quote>{first.quote}</p>
          <div class="flex flex-col gap-0.5">
            <p class="m-0 text-sm font-semibold leading-[1.3] text-navy" data-sizer-author>{first.author}</p>
            <p class="m-0 text-xs font-medium leading-[1.3] text-muted" data-sizer-role>{first.role}</p>
          </div>
        </div>
        <div data-text-stage class="absolute inset-x-0 top-0 flex flex-col gap-[19px] will-change-[transform,opacity]">
          <p class="m-0 text-lg font-medium leading-[1.3] tracking-[-0.02em] text-navy sm:text-[22px]" data-quote></p>
          <div class="flex flex-col gap-0.5">
            <p class="m-0 text-sm font-semibold leading-[1.3] text-navy" data-author></p>
            <p class="m-0 text-xs font-medium leading-[1.3] text-muted" data-role></p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 flex items-center gap-1.5 md:mt-0">
      <button
        type="button"
        data-prev
        aria-label="Témoignage précédent"
        class="grid h-6 w-6 cursor-pointer place-items-center rounded-full border border-navy/15 bg-transparent p-0 text-navy transition-[opacity,transform] duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:enabled:scale-[1.08] active:enabled:scale-[0.94] disabled:cursor-default disabled:opacity-40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan"
      >
        <svg class="h-3 w-3 opacity-70" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7.5 2.5 3.5 6l4 3.5" />
        </svg>
      </button>
      <button
        type="button"
        data-next
        aria-label="Témoignage suivant"
        class="grid h-6 w-6 cursor-pointer place-items-center rounded-full border border-navy/15 bg-transparent p-0 text-navy transition-[opacity,transform] duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:enabled:scale-[1.08] active:enabled:scale-[0.94] disabled:cursor-default disabled:opacity-40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan"
      >
        <svg class="h-3 w-3 opacity-70" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m4.5 2.5 4 3.5-4 3.5" />
        </svg>
      </button>
    </div>
  </div>

  <script type="application/json" data-testimonials-json set:html={dataJson} />
</div>

<script>
  const CELL = 121.33;
  const GAP = 8;
  const STEP = 3 * (CELL + GAP);
  const EXIT_MS = 240;
  const SLIDE_MS = 800;
  const EASE_INOUT = 'cubic-bezier(0.65,0,0.35,1)';

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function splitChars(text: string, startIndex: number, staggerMs: number) {
    let idx = startIndex;
    const words = text.split(' ');
    let html = '';
    words.forEach((word, wi) => {
      html += '<span class="inline-block whitespace-nowrap">';
      for (const ch of Array.from(word)) {
        const delay = idx * staggerMs;
        idx++;
        html += `<span class="scroll-reel-char" style="animation-delay:${delay}ms">${escapeHtml(ch)}</span>`;
      }
      html += '</span>';
      if (wi < words.length - 1) {
        idx++;
        html += ' ';
      }
    });
    return html;
  }

  function initReel(root: HTMLElement) {
    if (root.dataset.reelBound === '1') return;
    root.dataset.reelBound = '1';

    const jsonEl = root.querySelector('script[data-testimonials-json]');
    const testimonials: { quote: string; author: string; role?: string }[] = jsonEl
      ? JSON.parse(jsonEl.textContent || '[]')
      : [];
    const count = testimonials.length;
    if (!count) return;

    const staggerMs = Number(root.dataset.stagger) || 6;
    const centerIdx = (count - 1) / 2;

    const leftCol = root.querySelector<HTMLElement>('[data-col="left"]');
    const midCol = root.querySelector<HTMLElement>('[data-col="middle"]');
    const rightCol = root.querySelector<HTMLElement>('[data-col="right"]');
    const textStage = root.querySelector<HTMLElement>('[data-text-stage]');
    const quoteEl = root.querySelector<HTMLElement>('[data-quote]');
    const authorEl = root.querySelector<HTMLElement>('[data-author]');
    const roleEl = root.querySelector<HTMLElement>('[data-role]');
    const sizerQuote = root.querySelector<HTMLElement>('[data-sizer-quote]');
    const sizerAuthor = root.querySelector<HTMLElement>('[data-sizer-author]');
    const sizerRole = root.querySelector<HTMLElement>('[data-sizer-role]');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]');

    let index = 0;
    let displayIndex = 0;
    let animating = false;

    function renderText(i: number) {
      const t = testimonials[i];
      const authorStart = t.quote.length + 6;
      const roleStart = authorStart + t.author.length + 6;
      if (quoteEl) quoteEl.innerHTML = splitChars(t.quote, 0, staggerMs);
      if (authorEl) authorEl.innerHTML = splitChars(t.author, authorStart, staggerMs);
      if (roleEl) roleEl.innerHTML = t.role ? splitChars(t.role, roleStart, staggerMs) : '';
      if (sizerQuote) sizerQuote.textContent = t.quote;
      if (sizerAuthor) sizerAuthor.textContent = t.author;
      if (sizerRole) sizerRole.textContent = t.role || '';
    }

    function updateColumns() {
      const middleY = (centerIdx - index) * STEP;
      const sideY = -middleY;
      if (midCol) midCol.style.transform = `translateY(${middleY}px)`;
      if (leftCol) leftCol.style.transform = `translateY(${sideY}px)`;
      if (rightCol) rightCol.style.transform = `translateY(${sideY}px)`;
    }

    function updateButtons() {
      if (prevBtn) prevBtn.disabled = index === 0;
      if (nextBtn) nextBtn.disabled = index === count - 1;
    }

    function paginate(dir: 1 | -1) {
      if (animating) return;
      const next = index + dir;
      if (next < 0 || next >= count) return;
      animating = true;
      index = next;
      updateColumns();
      updateButtons();
      textStage?.classList.add('scroll-reel-exit');
      setTimeout(() => {
        displayIndex = index;
        renderText(displayIndex);
        textStage?.classList.remove('scroll-reel-exit');
      }, EXIT_MS);
      setTimeout(() => {
        animating = false;
      }, SLIDE_MS);
    }

    prevBtn?.addEventListener('click', () => paginate(-1));
    nextBtn?.addEventListener('click', () => paginate(1));
    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        paginate(1);
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        paginate(-1);
      }
    });

    renderText(0);
    updateButtons();

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        [leftCol, midCol, rightCol].forEach((col) => {
          if (col) col.style.transition = `transform ${SLIDE_MS}ms ${EASE_INOUT}`;
        });
      });
    });
  }

  function initAllReels() {
    document.querySelectorAll<HTMLElement>('[data-scroll-reel]').forEach(initReel);
  }

  document.addEventListener('astro:page-load', initAllReels);
</script>
