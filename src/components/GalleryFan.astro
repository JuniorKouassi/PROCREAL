---
/**
 * Fan-of-cards carousel, ported to vanilla Astro + GSAP (already a
 * project dependency) from a React/GSAP reference. Up to 7 cards
 * shown at once, spread in a symmetric fan; hovering a card pushes
 * its neighbors aside. Beyond 7 cards, prev/next arrows cycle the
 * fan with an entrance/exit animation.
 *
 * cards: { imgUrl: string, alt?: string, linkUrl?: string }[]
 */
const { cards = [], class: className = '' } = Astro.props;
const needsPagination = cards.length > 7;
const cardsJson = JSON.stringify(cards).replace(/</g, '\\u003c');
---

<section data-fan-gallery class={`relative z-20 flex w-full flex-col items-center px-4 py-4 md:px-8 lg:py-8 ${className}`}>
  <div class="flex w-full max-w-[90rem] items-center justify-center">
    <div data-fan-layout class="fan-layout relative flex w-full max-w-[80rem] items-center justify-center">
      {cards.map((card, index) => {
        const img = <img src={card.imgUrl} loading="lazy" alt={card.alt || `Photo ${index + 1}`} class="pointer-events-none absolute inset-0 h-full w-full object-cover" />;
        return card.linkUrl ? (
          <a
            data-fan-card
            href={card.linkUrl}
            target={card.linkUrl.startsWith('http') ? '_blank' : '_self'}
            rel="noopener noreferrer"
            class="fan-card absolute block cursor-pointer overflow-hidden rounded-2xl shadow-[0_12px_30px_rgba(10,42,107,0.25)]"
          >
            {img}
          </a>
        ) : (
          <div data-fan-card class="fan-card absolute overflow-hidden rounded-2xl shadow-[0_12px_30px_rgba(10,42,107,0.25)]">
            {img}
          </div>
        );
      })}
    </div>
  </div>

  {needsPagination && (
    <div class="z-30 mt-4 flex items-center justify-center gap-4 md:mt-6">
      <button
        type="button"
        data-fan-prev
        aria-label="Précédent"
        class="relative flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full border-[1.5px] border-navy/15 bg-white text-navy/50 shadow-[0_4px_20px_rgba(10,42,107,0.12)] outline-none transition-colors duration-300 hover:border-navy/30 hover:text-navy active:opacity-70 md:h-12 md:w-12"
      >
        <svg class="relative z-[2] h-4 w-4 md:h-5 md:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>
      <div data-fan-dots class="flex items-center gap-2">
        {cards.map((_, i) => (
          <span data-fan-dot class:list={['h-2 w-2 rounded-full transition-all duration-300', i === 3 ? 'scale-[1.3] bg-navy/70' : 'bg-navy/15']} />
        ))}
      </div>
      <button
        type="button"
        data-fan-next
        aria-label="Suivant"
        class="relative flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full border-[1.5px] border-navy/15 bg-white text-navy/50 shadow-[0_4px_20px_rgba(10,42,107,0.12)] outline-none transition-colors duration-300 hover:border-navy/30 hover:text-navy active:opacity-70 md:h-12 md:w-12"
      >
        <svg class="relative z-[2] h-4 w-4 md:h-5 md:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>
    </div>
  )}

  <script type="application/json" data-fan-json set:html={cardsJson} />
</section>

<style>
  .fan-layout {
    height: 22rem;
  }
  .fan-card {
    width: 8.5rem;
    height: 10.5rem;
    left: 50%;
    top: 50%;
    margin-left: -4.25rem;
    margin-top: -5.25rem;
  }
  @media (min-width: 480px) {
    .fan-layout { height: 26rem; }
    .fan-card { width: 9.5rem; height: 11.75rem; margin-left: -4.75rem; margin-top: -5.875rem; }
  }
  @media (min-width: 640px) {
    .fan-layout { height: 28rem; }
    .fan-card { width: 10.5rem; height: 13rem; margin-left: -5.25rem; margin-top: -6.5rem; }
  }
  @media (min-width: 768px) {
    .fan-layout { height: 34rem; }
    .fan-card { width: 12.5rem; height: 15.5rem; margin-left: -6.25rem; margin-top: -7.75rem; }
  }
  @media (min-width: 1024px) {
    .fan-layout { height: 38rem; }
    .fan-card { width: 14.5rem; height: 18rem; margin-left: -7.25rem; margin-top: -9rem; }
  }
</style>

<script>
  import gsap from 'gsap';

  const MAX_VISIBLE = 7;
  const HALF = 3;

  const FAN_POSITIONS = [
    { rot: -21, scale: 0.7756, x: -30, y: 7.3, zIndex: 1 },
    { rot: -14, scale: 0.8498, x: -22, y: 4.0, zIndex: 2 },
    { rot: -7, scale: 0.9346, x: -11, y: 1.3, zIndex: 3 },
    { rot: 0, scale: 1.0, x: 0, y: 0.0, zIndex: 10 },
    { rot: 7, scale: 0.9346, x: 11, y: 1.3, zIndex: 3 },
    { rot: 14, scale: 0.8498, x: 22, y: 4.0, zIndex: 2 },
    { rot: 21, scale: 0.7756, x: 30, y: 7.3, zIndex: 1 },
  ];

  function getResponsiveMultiplier(width: number) {
    if (width < 480) return 0.28;
    if (width < 640) return 0.38;
    if (width < 768) return 0.5;
    if (width < 1024) return 0.75;
    return 1.0;
  }

  function getHeightMultiplier(width: number) {
    let idealPx: number;
    if (width < 480) idealPx = 22 * 16;
    else if (width < 640) idealPx = 26 * 16;
    else if (width < 768) idealPx = 28 * 16;
    else if (width < 1024) idealPx = 34 * 16;
    else idealPx = 38 * 16;

    const available = window.innerHeight * 0.7;
    if (available >= idealPx) return 1;
    return available / idealPx;
  }

  function getSlotConfig(totalCards: number, slot: number) {
    if (totalCards >= MAX_VISIBLE) return FAN_POSITIONS[slot];
    const center = totalCards >> 1;
    const distance = totalCards > 1 ? (slot - center) / center : 0;
    const absDistance = Math.abs(distance);
    return {
      rot: distance * 21,
      scale: 1.0 - 0.2244 * absDistance * absDistance,
      x: distance * 30,
      y: absDistance * absDistance * 7.3,
      zIndex: 10 - Math.abs(slot - center),
    };
  }

  function initFan(section: HTMLElement) {
    if (section.dataset.fanBound === '1') return;
    section.dataset.fanBound = '1';

    const container = section.querySelector<HTMLElement>('[data-fan-layout]');
    const jsonEl = section.querySelector('[data-fan-json]');
    const cards: { imgUrl: string }[] = jsonEl ? JSON.parse(jsonEl.textContent || '[]') : [];
    const totalCards = cards.length;
    if (!container || !totalCards) return;

    const needsPagination = totalCards > MAX_VISIBLE;
    const cardElements = Array.from(container.querySelectorAll<HTMLElement>('[data-fan-card]'));
    const dots = Array.from(section.querySelectorAll<HTMLElement>('[data-fan-dot]'));
    const prevBtn = section.querySelector<HTMLButtonElement>('[data-fan-prev]');
    const nextBtn = section.querySelector<HTMLButtonElement>('[data-fan-next]');

    let centerIndex = needsPagination ? HALF : totalCards >> 1;
    let isAnimating = false;
    let hasEntered = false;
    let direction: 'left' | 'right' | null = null;
    let prevVisible = new Set<number>();

    function getVisibleMap(center: number) {
      const map = new Map<number, number>();
      if (!needsPagination) {
        cards.forEach((_, i) => map.set(i, i));
        return map;
      }
      for (let slot = 0; slot < MAX_VISIBLE; slot++) {
        map.set((((center + slot - HALF) % totalCards) + totalCards) % totalCards, slot);
      }
      return map;
    }

    function updateDots() {
      dots.forEach((dot, i) => {
        const active = i === centerIndex;
        dot.classList.toggle('bg-navy/70', active);
        dot.classList.toggle('scale-[1.3]', active);
        dot.classList.toggle('bg-navy/15', !active);
      });
    }

    let activeSlot: number | null = null;
    let leaveTimer: ReturnType<typeof setTimeout> | null = null;

    function updateHoverLayout(visibleEntries: { el: HTMLElement; slot: number }[], hoveredSlot: number | null, slotCount: number) {
      const mult = getResponsiveMultiplier(window.innerWidth);
      const hM = getHeightMultiplier(window.innerWidth);
      const centerSlot = visibleEntries.length >> 1;

      visibleEntries.forEach(({ el, slot }) => {
        const base = getSlotConfig(slotCount, slot);
        let targetX = base.x * mult;
        let targetY = base.y * hM;
        let targetRot = base.rot;
        let targetScale = base.scale;
        let delay = 0;

        if (hoveredSlot !== null) {
          const dist = Math.abs(slot - hoveredSlot);
          delay = dist * 0.02;

          if (slot === hoveredSlot) {
            targetY -= 2.5 * hM;
            targetScale *= 1.08;
          } else {
            const normalized = centerSlot > 0 ? (slot - centerSlot) / centerSlot : 0;
            const pushStrength = 8 * (1 - Math.abs(normalized)) * (1 + 0.2 * Math.max(0, 3 - dist));
            if (slot < hoveredSlot) {
              targetX -= pushStrength * mult;
              targetRot -= 3 / (dist + 1);
            } else {
              targetX += pushStrength * mult;
              targetRot += 3 / (dist + 1);
            }
            if (slot === visibleEntries.length - 1 && hoveredSlot < centerSlot) targetY -= 1 * hM;
            if (slot === 0 && hoveredSlot > centerSlot) targetY -= 1 * hM;
          }
        } else {
          delay = Math.abs(slot - centerSlot) * 0.02;
        }

        gsap.to(el, {
          x: `${targetX}rem`,
          y: `${targetY}rem`,
          rotation: targetRot,
          scale: targetScale,
          duration: 0.5,
          delay,
          ease: 'elastic.out(1,.75)',
          overwrite: 'auto',
        });
        gsap.set(el, { zIndex: base.zIndex });
      });
    }

    let removeHoverListeners: (() => void) | null = null;

    function render() {
      const visibleMap = getVisibleMap(centerIndex);
      const previouslyVisible = prevVisible;
      const isFirstMount = !hasEntered;
      const multiplier = getResponsiveMultiplier(window.innerWidth);
      const hMult = getHeightMultiplier(window.innerWidth);
      const slotCount = needsPagination ? MAX_VISIBLE : totalCards;
      const config = (slot: number) => getSlotConfig(slotCount, slot);

      if (isFirstMount) isAnimating = true;

      let completedCount = 0;
      const visibleCount = visibleMap.size;
      const onCardDone = () => {
        if (++completedCount >= visibleCount) {
          isAnimating = false;
          if (isFirstMount) hasEntered = true;
        }
      };

      cardElements.forEach((card, cardIndex) => {
        const slot = visibleMap.get(cardIndex);
        const wasVisible = previouslyVisible.has(cardIndex);

        if (slot !== undefined) {
          const { x, y, rot, scale, zIndex } = config(slot);
          const target = {
            x: `${x * multiplier}rem`,
            y: `${y * hMult}rem`,
            rotation: rot,
            scale,
            opacity: 1,
            zIndex,
          };

          if (isFirstMount) {
            gsap.set(card, { x: 0, y: `${12 * hMult}rem`, rotation: 0, scale: 0.5, opacity: 0 });
            gsap.to(card, { ...target, duration: 1.2, ease: 'elastic.out(1.05,.78)', delay: 0.2 + slot * 0.06, onComplete: onCardDone });
          } else if (!wasVisible) {
            const enterX = direction === 'right' ? 40 : -40;
            gsap.set(card, { x: `${enterX}rem`, y: `${y * hMult}rem`, rotation: direction === 'right' ? 30 : -30, scale: 0.5, opacity: 0 });
            gsap.to(card, { ...target, duration: 0.6, ease: 'power2.out', onComplete: onCardDone });
          } else {
            gsap.to(card, { ...target, duration: 0.5, ease: 'power2.out', onComplete: onCardDone });
          }
        } else if (wasVisible) {
          const exitX = direction === 'right' ? -40 : 40;
          gsap.to(card, { x: `${exitX}rem`, opacity: 0, scale: 0.5, rotation: direction === 'right' ? -30 : 30, duration: 0.4, ease: 'power2.in', zIndex: 0 });
        } else if (isFirstMount) {
          gsap.set(card, { opacity: 0, scale: 0.3, x: 0, y: 0, zIndex: 0 });
        }
      });

      prevVisible = new Set(visibleMap.keys());
      updateDots();

      removeHoverListeners?.();

      const visibleEntries: { el: HTMLElement; slot: number }[] = [];
      cardElements.forEach((el, i) => {
        const slot = visibleMap.get(i);
        if (slot !== undefined) visibleEntries.push({ el, slot });
      });
      visibleEntries.sort((a, b) => a.slot - b.slot);

      activeSlot = null;
      if (leaveTimer) {
        clearTimeout(leaveTimer);
        leaveTimer = null;
      }

      const enterHandlers = visibleEntries.map(({ el, slot }) => {
        const handler = () => {
          if (isAnimating) return;
          if (leaveTimer) {
            clearTimeout(leaveTimer);
            leaveTimer = null;
          }
          if (activeSlot !== slot) {
            activeSlot = slot;
            updateHoverLayout(visibleEntries, slot, slotCount);
          }
        };
        el.addEventListener('mouseenter', handler);
        return { el, handler };
      });

      const onMouseLeave = () => {
        if (isAnimating) return;
        if (leaveTimer) clearTimeout(leaveTimer);
        leaveTimer = setTimeout(() => {
          activeSlot = null;
          updateHoverLayout(visibleEntries, null, slotCount);
        }, 50);
      };
      container.addEventListener('mouseleave', onMouseLeave);

      const onResize = () => {
        if (!isAnimating) updateHoverLayout(visibleEntries, activeSlot, slotCount);
      };
      window.addEventListener('resize', onResize);

      removeHoverListeners = () => {
        enterHandlers.forEach(({ el, handler }) => el.removeEventListener('mouseenter', handler));
        container.removeEventListener('mouseleave', onMouseLeave);
        window.removeEventListener('resize', onResize);
        if (leaveTimer) clearTimeout(leaveTimer);
      };
    }

    function cycle(dir: 'left' | 'right') {
      if (isAnimating || !needsPagination) return;
      isAnimating = true;
      direction = dir;
      centerIndex = dir === 'right' ? (centerIndex + 1) % totalCards : (centerIndex - 1 + totalCards) % totalCards;
      render();
    }

    prevBtn?.addEventListener('click', () => cycle('left'));
    nextBtn?.addEventListener('click', () => cycle('right'));

    render();
  }

  function initAllFans() {
    document.querySelectorAll<HTMLElement>('[data-fan-gallery]').forEach(initFan);
  }

  document.addEventListener('astro:page-load', initAllFans);
</script>
