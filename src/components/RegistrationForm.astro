---
import { useTranslations } from '../i18n/utils';

const { lang, formations = [], preselected } = Astro.props;
const t = useTranslations(lang);
const paymentMethods = ['Wave', 'Orange Money', 'WhatsApp'];
---

<div data-registration class="reveal mx-auto max-w-2xl rounded-2xl bg-white p-8 shadow-sm ring-1 ring-navy/5">
  <div class="mb-8 flex items-center gap-2">
    {[1, 2, 3].map((step) => (
      <div class="h-1.5 flex-1 rounded-full bg-navy/10 transition-colors" data-step-indicator={step}></div>
    ))}
  </div>

  <form data-registration-form>
    <div data-step-panel="1" class="space-y-4">
      <h3 class="font-heading text-xl font-bold text-navy">{t('form.selectFormation')}</h3>
      <div class="grid gap-3 sm:grid-cols-2">
        {formations.map((formation) => (
          <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-navy/15 p-4 text-sm font-medium text-navy transition-colors [&:has(:checked)]:border-cyan [&:has(:checked)]:bg-cyan/5">
            <input
              type="radio"
              name="formation"
              value={formation.slug}
              data-title={formation.title}
              required
              checked={formation.slug === preselected}
              class="accent-cyan"
            />
            {formation.title}
          </label>
        ))}
      </div>
    </div>

    <div data-step-panel="2" class="hidden space-y-4">
      <h3 class="font-heading text-xl font-bold text-navy">{t('form.personalInfo')}</h3>
      <input name="name" type="text" required placeholder={t('form.name')} class="w-full rounded-lg border border-navy/15 px-4 py-3 text-sm focus:border-cyan focus:outline-none" />
      <input name="email" type="email" required placeholder={t('form.email')} class="w-full rounded-lg border border-navy/15 px-4 py-3 text-sm focus:border-cyan focus:outline-none" />
      <input name="phone" type="tel" required placeholder={t('form.phone')} class="w-full rounded-lg border border-navy/15 px-4 py-3 text-sm focus:border-cyan focus:outline-none" />
    </div>

    <div data-step-panel="3" class="hidden space-y-4">
      <h3 class="font-heading text-xl font-bold text-navy">{t('form.paymentMethod')}</h3>
      <div class="grid gap-3 sm:grid-cols-3">
        {paymentMethods.map((method) => (
          <label class="flex cursor-pointer flex-col items-center gap-2 rounded-xl border border-navy/15 p-4 text-center text-sm font-semibold text-navy transition-colors [&:has(:checked)]:border-cyan [&:has(:checked)]:bg-cyan/5">
            <input type="radio" name="payment" value={method} required class="accent-cyan" />
            <span>{method}</span>
          </label>
        ))}
      </div>
      <div data-recap class="rounded-xl bg-cream p-4 text-sm text-muted"></div>
    </div>

    <div class="mt-8 flex items-center justify-between">
      <button type="button" data-step-prev class="hidden text-sm font-semibold text-navy">&larr; {t('form.previous')}</button>
      <button type="button" data-step-next class="ml-auto rounded-full bg-navy px-6 py-3 font-semibold text-white">{t('form.next')}</button>
      <button type="submit" data-step-submit class="ml-auto hidden rounded-full bg-yellow px-6 py-3 font-semibold text-navy">{t('form.confirm')}</button>
    </div>
  </form>

  <div data-step-panel="4" class="hidden text-center">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-cyan/10 text-cyan">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    <h3 class="mt-4 font-heading text-xl font-bold text-navy">{t('form.confirmationTitle')}</h3>
    <p class="mt-2 text-sm text-muted">{t('form.confirmationText')}</p>
    <a data-whatsapp-finish href="#" target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex rounded-full bg-[#25D366] px-7 py-3 font-semibold text-white">
      {t('form.finishOnWhatsapp')}
    </a>
  </div>
</div>

<script>
  import { submitForm, whatsappUrl } from '../lib/form.js';

  function bindRegistration() {
    const root = document.querySelector('[data-registration]');
    if (!root) return;
    const form = root.querySelector('[data-registration-form]');
    const panels = root.querySelectorAll('[data-step-panel]');
    const indicators = root.querySelectorAll('[data-step-indicator]');
    const prevBtn = root.querySelector('[data-step-prev]');
    const nextBtn = root.querySelector('[data-step-next]');
    const submitBtn = root.querySelector('[data-step-submit]');
    const recap = root.querySelector('[data-recap]');
    const totalSteps = 3;
    let step = 1;

    function render() {
      panels.forEach((panel) => {
        panel.classList.toggle('hidden', Number(panel.dataset.stepPanel) !== step);
      });
      indicators.forEach((indicator) => {
        const active = Number(indicator.dataset.stepIndicator) <= step;
        indicator.classList.toggle('bg-cyan', active);
        indicator.classList.toggle('bg-navy/10', !active);
      });
      prevBtn.classList.toggle('hidden', step === 1);
      nextBtn.classList.toggle('hidden', step === totalSteps);
      submitBtn.classList.toggle('hidden', step !== totalSteps);
      if (step === totalSteps && recap) {
        const data = new FormData(form);
        const checkedRadio = form.querySelector('input[name="formation"]:checked');
        const formationTitle = checkedRadio?.dataset.title || data.get('formation') || '';
        recap.textContent = `${formationTitle} — ${data.get('name') || ''} (${data.get('phone') || ''})`;
      }
    }

    function validateStep() {
      const panel = root.querySelector(`[data-step-panel="${step}"]`);
      return [...panel.querySelectorAll('input, select, textarea')].every((input) => input.reportValidity());
    }

    nextBtn.addEventListener('click', () => {
      if (!validateStep()) return;
      step = Math.min(step + 1, totalSteps);
      render();
    });
    prevBtn.addEventListener('click', () => {
      step = Math.max(step - 1, 1);
      render();
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!validateStep()) return;
      const lang = document.documentElement.lang === 'en' ? 'en' : 'fr';
      const data = new FormData(form);
      const checkedRadio = form.querySelector('input[name="formation"]:checked');
      const formationTitle = checkedRadio?.dataset.title || data.get('formation') || '';
      try {
        await submitForm(form);
      } catch (error) {
        // webhook may not be configured yet — WhatsApp remains the fallback
      }
      const message =
        lang === 'en'
          ? `Hello PROcréal, I just registered for "${formationTitle}" — ${data.get('name')} (${data.get('phone')}). Payment: ${data.get('payment')}.`
          : `Bonjour PROcréal, je viens de m'inscrire à "${formationTitle}" — ${data.get('name')} (${data.get('phone')}). Paiement : ${data.get('payment')}.`;
      const finishLink = root.querySelector('[data-whatsapp-finish]');
      if (finishLink) finishLink.href = whatsappUrl(message);
      form.classList.add('hidden');
      panels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.stepPanel !== '4'));
    });

    render();
  }
  document.addEventListener('astro:page-load', bindRegistration);
</script>
