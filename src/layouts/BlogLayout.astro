---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, localizePath } from '../i18n/utils';
import { blogPostingSchema, breadcrumbSchema } from '../lib/seo';

const { post, path } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const categoryLabels = {
  fr: {
    'conseils-metier': 'Conseils métier',
    'etudes-de-cas': 'Études de cas',
    actualites: 'Actualités PROcréal',
    temoignages: 'Témoignages',
  },
  en: {
    'conseils-metier': 'Career advice',
    'etudes-de-cas': 'Case studies',
    actualites: 'PROcréal news',
    temoignages: 'Testimonials',
  },
};

const formattedDate = new Intl.DateTimeFormat(lang === 'en' ? 'en-GB' : 'fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(post.pubDate);

const jsonLd = [
  blogPostingSchema(post, path),
  breadcrumbSchema([
    { name: lang === 'en' ? 'Home' : 'Accueil', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: post.title, url: path },
  ]),
];
---

<BaseLayout title={post.title} description={post.excerpt} image={post.image} jsonLd={jsonLd}>
  <article class="bg-cream pb-20 pt-36 lg:pt-44">
    <div class="mx-auto max-w-3xl px-5 lg:px-8">
      <p class="reveal text-sm font-semibold uppercase tracking-wide text-cyan">{categoryLabels[lang][post.category]}</p>
      <h1 class="reveal mt-3 font-heading text-3xl font-bold leading-tight text-navy balance lg:text-4xl">{post.title}</h1>
      <div class="reveal mt-4 flex items-center gap-3 text-sm text-muted">
        <span>{post.author}</span>
        <span>&bull;</span>
        <time datetime={post.pubDate.toISOString()}>{formattedDate}</time>
      </div>
      <div class="reveal prose prose-slate mt-10 max-w-none prose-headings:font-heading prose-headings:text-navy prose-a:text-cyan">
        <slot />
      </div>
      <a href={localizePath('/blog', lang)} class="mt-12 inline-flex items-center gap-2 font-semibold text-cyan hover:underline">
        &larr; {lang === 'en' ? 'Back to blog' : 'Retour au blog'}
      </a>
    </div>
  </article>
</BaseLayout>
