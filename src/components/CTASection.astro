---
import { localizePath } from '../i18n/utils';

const { lang, eyebrow, title, subtitle, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
const isExternal = secondaryHref?.startsWith('http');
---

<section class="reveal relative overflow-hidden bg-navy py-20 text-center text-white">
  <div class="absolute inset-0 bg-gradient-to-br from-navy via-navy to-cyan/20"></div>
  <div class="relative mx-auto max-w-2xl px-5">
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-cyan">{eyebrow}</p>}
    <h2 class="mt-3 font-heading text-3xl font-bold balance lg:text-4xl">{title}</h2>
    {subtitle && <p class="mt-4 text-white/70">{subtitle}</p>}
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href={localizePath(primaryHref, lang)}
        class="rounded-full bg-yellow px-7 py-3 font-semibold text-navy transition-transform hover:scale-105"
      >
        {primaryLabel}
      </a>
      {secondaryHref && (
        <a
          href={secondaryHref}
          target={isExternal ? '_blank' : undefined}
          rel={isExternal ? 'noopener noreferrer' : undefined}
          class="rounded-full border border-white/30 px-7 py-3 font-semibold text-white transition-colors hover:bg-white/10"
        >
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
