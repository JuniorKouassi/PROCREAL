---
import NavIcon from './NavIcon.astro';
import { localizePath, useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const items = [
  { href: '/formations', label: t('nav.formations'), icon: 'cap' },
  { href: '/cours-du-soir', label: t('nav.coursDuSoir'), icon: 'moon' },
  { href: '/masterclass', label: t('nav.masterclass'), icon: 'star' },
  { href: '/a-propos', label: t('nav.aPropos'), icon: 'info' },
  { href: '/galerie', label: t('nav.galerie'), icon: 'image' },
  { href: '/blog', label: t('nav.blog'), icon: 'doc' },
];

function isActive(href) {
  const target = localizePath(href, lang).replace(/\/$/, '') || '/';
  return pathname === target || pathname.startsWith(`${target}/`);
}
---

<nav data-bottom-nav class="fixed inset-x-0 bottom-0 z-40 h-16 border-t border-white/10 bg-navy-dark lg:hidden" aria-label="Navigation mobile">
  <div class="grid h-full grid-cols-6">
    {items.map((item) => {
      const active = isActive(item.href);
      return (
        <a
          href={localizePath(item.href, lang)}
          class:list={[
            'relative flex flex-col items-center justify-center gap-1 text-[9px] font-semibold uppercase tracking-wide transition-colors',
            active ? 'text-cyan' : 'text-white/55',
          ]}
        >
          {active && <span class="absolute top-0 h-0.5 w-7 rounded-full bg-yellow"></span>}
          <NavIcon name={item.icon} class="h-5 w-5" />
          <span class="leading-none">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>
