---
const { name, class: className = 'h-5 w-5' } = Astro.props;
---

{name === 'cap' && (
  <svg viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path
      d="M12 2 2 7l10 5 10-5-10-5ZM6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
)}
{name === 'clock' && (
  <svg viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
    <path d="M12 7.5V12l3.2 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === 'award' && (
  <svg viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.8" />
    <path d="M8.7 12.4 7 21l5-3 5 3-1.7-8.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === 'info' && (
  <svg viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
    <path d="M12 11v5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
    <circle cx="12" cy="8" r="0.9" fill="currentColor" stroke="none" />
  </svg>
)}
{name === 'image' && (
  <svg viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.8" />
    <circle cx="8.5" cy="9.5" r="1.5" stroke="currentColor" stroke-width="1.8" />
    <path d="M21 16l-5.5-5.5L9 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
