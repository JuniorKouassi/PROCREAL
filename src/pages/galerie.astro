---
import PageLayout from '../layouts/PageLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import PhotoStack3D from '../components/PhotoStack3D.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);

const stackImages = [
  '/img/kakemono-promotion.jpg',
  '/img/team-salle-kassi-francois.jpg',
  '/img/remise-diplome-2025.jpg',
  '/img/promo-assistant-architecte-1.jpg',
  '/img/cours-salle-kassi-francois.jpg',
  '/img/promo-assistant-architecte-2.jpg',
  '/img/cours-autocad-presentation.jpg',
  '/img/remise-diplome-kouadio-2026.jpg',
  '/img/remise-diplome-savane-kouakou-2026.jpg',
  '/img/photo-groupe-remise-diplomes-2026-1.jpg',
  '/img/photo-groupe-remise-diplomes-2026-2.jpg',
  '/img/flyer-archicad-20h-remise-diplome.jpg',
];

const categories = ['Toutes', 'Promotions', 'Remises de diplômes', 'Cours', 'Événements'];

const palette = [
  ['0A2A6B', '3DA9E0'],
  ['3DA9E0', '0A2A6B'],
  ['0A2A6B', 'F5C518'],
  ['071c4a', '3DA9E0'],
];

const images = [
  { category: 'Promotions', caption: 'Kakémono PROcréal — remise de certificat', src: '/img/kakemono-promotion.jpg' },
  { category: 'Cours', caption: "L'équipe PROcréal, Salle de Conférence KASSI François", src: '/img/team-salle-kassi-francois.jpg' },
  { category: 'Remises de diplômes', caption: 'Cérémonie de remise de diplômes 2025', src: '/img/remise-diplome-2025.jpg' },
  { category: 'Promotions', caption: '3e promotion — Assistants Architectes', src: '/img/promo-assistant-architecte-1.jpg' },
  { category: 'Événements', caption: 'Masterclass ArchiCAD, édition 36 ans' },
  { category: 'Cours', caption: 'Travaux pratiques ArchiCAD, Salle KASSI François', src: '/img/cours-salle-kassi-francois.jpg' },
  { category: 'Remises de diplômes', caption: 'Photo de groupe — diplômés 2025', src: '/img/promo-assistant-architecte-2.jpg' },
  { category: 'Événements', caption: 'Coupure de gâteau, anniversaire PROcréal' },
  { category: 'Cours', caption: 'Présentation AutoCAD, séance pratique', src: '/img/cours-autocad-presentation.jpg' },
  { category: 'Promotions', caption: '3e promotion — Remise de diplôme ArchiCAD 20h', src: '/img/flyer-archicad-20h-remise-diplome.jpg' },
  { category: 'Événements', caption: 'Networking entre anciens élèves' },
  { category: 'Remises de diplômes', caption: 'Diplômés Cours du soir 2025' },
  { category: 'Remises de diplômes', caption: 'Remise de certificat à KOUADIO Akissi Marie Christelle', src: '/img/remise-diplome-kouadio-2026.jpg' },
  { category: 'Remises de diplômes', caption: 'Remise de certificats à SAVANE Nahoua et KOUAKOU Kouamé Ruphin', src: '/img/remise-diplome-savane-kouakou-2026.jpg' },
  { category: 'Remises de diplômes', caption: 'Photo de groupe — cérémonie de remise de diplômes', src: '/img/photo-groupe-remise-diplomes-2026-1.jpg' },
  { category: 'Remises de diplômes', caption: 'Photo de groupe — équipe et diplômés', src: '/img/photo-groupe-remise-diplomes-2026-2.jpg' },
].map((image, index) => {
  const [from, to] = palette[index % palette.length];
  return {
    ...image,
    src: image.src || `https://placehold.co/600x${index % 3 === 0 ? 750 : 600}/${from}/${to}?text=${encodeURIComponent(image.category)}`,
  };
});
---

<PageLayout
  title="Galerie — Promotions, diplômes et événements PROcréal"
  description="Découvrez les promotions, remises de diplômes, cours et événements du centre de formation PROcréal à Abidjan."
  heading="Galerie"
  subheading="La vie du centre : promotions, remises de diplômes, cours et événements."
  breadcrumb={[
    { name: 'Accueil', url: '/' },
    { name: t('nav.galerie'), url: '/galerie' },
  ]}
>
  <section class="overflow-hidden bg-navy-dark py-14 md:py-20">
    <div class="mx-auto max-w-6xl px-5 lg:px-8">
      <p class="reveal text-center text-sm font-semibold uppercase tracking-wide text-cyan">Déplace le curseur</p>
      <PhotoStack3D images={stackImages} class="reveal mt-4" />
    </div>
  </section>

  <section class="bg-cream py-16">
    <div class="mx-auto max-w-6xl px-5 lg:px-8">
      <div data-gallery-filters class="reveal flex flex-wrap gap-2">
        {categories.map((category, index) => (
          <button
            type="button"
            data-category-filter={category === 'Toutes' ? 'all' : category}
            class:list={[
              'rounded-full border px-4 py-2 text-sm font-semibold transition-colors',
              index === 0 ? 'border-navy bg-navy text-white' : 'border-navy/15 text-navy hover:bg-navy hover:text-white',
            ]}
          >
            {category}
          </button>
        ))}
      </div>

      <div class="mt-10">
        <GalleryGrid images={images} />
      </div>
    </div>
  </section>
</PageLayout>

<script>
  function bindGalleryFilters() {
    const filters = document.querySelectorAll('[data-category-filter]');
    const items = document.querySelectorAll('[data-gallery-item]');
    if (!filters.length || !items.length) return;

    filters.forEach((button) => {
      button.addEventListener('click', () => {
        const category = button.dataset.categoryFilter;
        filters.forEach((btn) => {
          const isActive = btn === button;
          btn.classList.toggle('bg-navy', isActive);
          btn.classList.toggle('text-white', isActive);
          btn.classList.toggle('border-navy', isActive);
          btn.classList.toggle('text-navy', !isActive);
          btn.classList.toggle('border-navy/15', !isActive);
        });
        items.forEach((item) => {
          const matches = category === 'all' || item.dataset.category === category;
          item.classList.toggle('hidden', !matches);
        });
      });
    });
  }
  document.addEventListener('astro:page-load', bindGalleryFilters);
</script>
