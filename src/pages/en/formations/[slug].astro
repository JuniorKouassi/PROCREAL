---
import { getCollection } from 'astro:content';
import FormationDetailLayout from '../../../components/FormationDetailLayout.astro';
import Accordion from '../../../components/Accordion.astro';
import Testimonial from '../../../components/Testimonial.astro';
import { localizePath, useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const formations = await getCollection('formations');
  return formations.map((formation) => ({ params: { slug: formation.id }, props: { formation } }));
}

const { formation } = Astro.props;
const lang = 'en';
const t = useTranslations(lang);
const data = formation.data;
const path = `/en/formations/${formation.id}`;

const moduleDescriptions = {
  'Understanding architectural drawing': 'Reading plans, representation standards and the basics of hand technical drawing.',
  AutoCAD: 'Full hands-on training on AutoCAD to produce precise, standardized 2D plans.',
  ArchiCAD: 'Moving to the 3D digital model: walls, slabs, roofs, joinery and automatic documentation.',
  'AutoCAD Architecture 2D': 'Standardized 2D plans, dimensions and networks in AutoCAD Architecture.',
  'ArchiCAD Architecture 3D': 'Full 3D digital model, from shell and core to joinery.',
  '3D design': 'First volumes and first models in ArchiCAD.',
  '2D plans': 'Producing clear, usable 2D plans.',
  'Professional renders': 'Bringing your projects to life with client-ready renders.',
};

function moduleTopic(label) {
  const parts = label.split('—');
  return parts[parts.length - 1].trim();
}

const modulesEn = data.modules_en;
const moduleItems = modulesEn?.map((label) => ({
  title: label,
  content: moduleDescriptions[moduleTopic(label)] || 'Guided learning and hands-on coaching on this module.',
}));

const faqItems = data.faq_en?.map((item) => ({ title: item.question, content: item.answer }));

const testimonials = (await getCollection('testimonials')).filter((item) => item.data.formationSlug === formation.id);

const nextSessionLabel = data.startDate
  ? new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(data.startDate))
  : null;

const infoItems = [
  { label: t('common.duration'), value: data.duration_en },
  data.level_en && { label: t('common.level'), value: data.level_en },
  data.schedule_en && { label: t('common.schedule'), value: data.schedule_en },
  nextSessionLabel && { label: t('common.nextSession'), value: nextSessionLabel },
  data.location_en && { label: t('common.location'), value: data.location_en },
  data.price && { label: t('common.price'), value: `${data.price.toLocaleString('en-US')} ${data.currency}` },
  data.seats && { label: t('common.seatsLeft'), value: `${data.seats}` },
]
  .filter(Boolean)
  .slice(0, 6);

const whatsappMessage = `Hello PROcréal, I'd like information about the "${data.title_en}" course.`;
const whatsappHref = `https://wa.me/2250749817621?text=${encodeURIComponent(whatsappMessage)}`;
const registerHref = `${localizePath('/inscription', lang)}?formation=${encodeURIComponent(formation.id)}`;
---

<FormationDetailLayout
  formation={data}
  path={path}
  title={data.title_en}
  description={data.description_en}
  infoItems={infoItems}
>
  <div class="reveal rounded-2xl bg-cyan/10 p-5 text-sm text-navy ring-1 ring-cyan/20">
    {t('common.languageComingSoon')} —
    <a href={localizePath(`/formations/${formation.id}`, 'fr')} class="font-semibold underline">{t('common.viewInFrench')}</a>
  </div>

  <div class="reveal">
    <h2 class="font-heading text-2xl font-bold text-navy">{t('common.audience')}</h2>
    <p class="mt-3 leading-relaxed text-muted">{data.audience_en}</p>
  </div>

  {moduleItems && (
    <div class="reveal">
      <h2 class="font-heading text-2xl font-bold text-navy">{t('common.program')}</h2>
      <div class="mt-5">
        <Accordion items={moduleItems} />
      </div>
    </div>
  )}

  {data.program_en && (
    <div class="reveal">
      <h2 class="font-heading text-2xl font-bold text-navy">{t('common.program')}</h2>
      <ul class="mt-5 space-y-3">
        {data.program_en.map((item) => (
          <li class="flex items-start gap-3 text-sm leading-relaxed text-muted">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-cyan" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  )}

  {data.bonus_en && (
    <div class="reveal rounded-2xl bg-yellow/10 p-6 ring-1 ring-yellow/30">
      <h2 class="font-heading text-xl font-bold text-navy">{t('common.bonus')}</h2>
      <ul class="mt-4 space-y-2">
        {data.bonus_en.map((item) => (
          <li class="flex items-start gap-3 text-sm leading-relaxed text-ink">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-yellow"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="reveal">
    <h2 class="font-heading text-2xl font-bold text-navy">{t('common.prerequisites')}</h2>
    <ul class="mt-5 space-y-3">
      {data.prerequisites_en.map((item) => (
        <li class="flex items-start gap-3 text-sm leading-relaxed text-muted">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-cyan" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {item}
        </li>
      ))}
    </ul>
  </div>

  <div class="reveal">
    <h2 class="font-heading text-2xl font-bold text-navy">{t('common.outcomes')}</h2>
    <ul class="mt-5 grid gap-3 sm:grid-cols-2">
      {data.outcomes_en.map((item) => (
        <li class="flex items-start gap-3 rounded-xl bg-cream p-4 text-sm leading-relaxed text-ink">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-navy" viewBox="0 0 24 24" fill="none">
            <path d="M12 2 2 7l10 5 10-5-10-5ZM6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {item}
        </li>
      ))}
    </ul>
  </div>

  <div class="reveal rounded-2xl bg-navy p-8 text-white">
    <p class="text-sm font-semibold uppercase tracking-wide text-cyan">{t('common.instructor')}</p>
    <div class="mt-4 flex items-center gap-4">
      <img src="https://placehold.co/96x96/071c4a/3DA9E0?text=KL" alt={data.instructor} class="h-16 w-16 rounded-full object-cover" />
      <div>
        <p class="font-heading text-lg font-bold">{data.instructor}</p>
        <p class="text-sm text-white/60">Founder & Lead Instructor, FDFP-approved</p>
      </div>
    </div>
  </div>

  {testimonials.length > 0 && (
    <div class="reveal">
      <h2 class="font-heading text-2xl font-bold text-navy">{t('common.testimonials')}</h2>
      <div class="mt-5 grid gap-6 sm:grid-cols-2">
        {testimonials.map((item) => (
          <Testimonial
            name={item.data.name}
            role={item.data.role_en || item.data.role}
            quote={item.data.quote_en || item.data.quote}
            avatar={item.data.avatar}
          />
        ))}
      </div>
    </div>
  )}

  {faqItems && (
    <div class="reveal">
      <h2 class="font-heading text-2xl font-bold text-navy">{t('common.faq')}</h2>
      <div class="mt-5">
        <Accordion items={faqItems} />
      </div>
    </div>
  )}

  <Fragment slot="sidebar">
    <div class="space-y-4 rounded-2xl bg-white p-6 shadow-lg shadow-navy/10 ring-1 ring-navy/5">
      {data.price && (
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-muted">{t('common.price')}</p>
          <p class="mt-1 font-heading text-2xl font-bold text-navy">{data.price.toLocaleString('en-US')} {data.currency}</p>
          {data.registration && (
            <p class="text-xs text-muted">+ {data.registration.toLocaleString('en-US')} {data.currency} {t('common.registrationFee').toLowerCase()}</p>
          )}
        </div>
      )}
      {data.seats && (
        <p class="rounded-lg bg-yellow/10 px-3 py-2 text-xs font-semibold text-navy">
          {data.seats} {t('common.seatsLeft')}
        </p>
      )}
      <a href={registerHref} class="block rounded-full bg-cyan px-6 py-3 text-center font-semibold text-white transition-transform hover:scale-105">
        {t('cta.registerNow')}
      </a>
      <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="block rounded-full border border-navy/15 px-6 py-3 text-center font-semibold text-navy transition-colors hover:bg-navy hover:text-white">
        {t('cta.whatsapp')}
      </a>
      <div class="border-t border-navy/10 pt-4 text-xs text-muted">
        <p class="font-semibold text-navy">Payment methods</p>
        <div class="mt-2 flex gap-2">
          <span class="rounded-full bg-cream px-3 py-1">Wave</span>
          <span class="rounded-full bg-cream px-3 py-1">Orange Money</span>
          <span class="rounded-full bg-cream px-3 py-1">WhatsApp</span>
        </div>
      </div>
    </div>
  </Fragment>
</FormationDetailLayout>
