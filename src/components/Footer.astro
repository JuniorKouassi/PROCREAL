---
import { getCollection } from 'astro:content';
import Logo from './Logo.astro';
import { useTranslations, localizePath, localizedField } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);

const formations = (await getCollection('formations')).slice(0, 4);

const usefulLinks = [
  { href: '/a-propos', label: t('nav.aPropos') },
  { href: '/galerie', label: t('nav.galerie') },
  { href: '/blog', label: t('nav.blog') },
  { href: '/espace-apprenant', label: t('nav.espaceApprenant') },
];

const socials = [
  {
    label: 'Facebook',
    href: 'https://facebook.com/procreal.ci',
    icon: 'M22 12.06C22 6.51 17.52 2 12 2S2 6.51 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.91h-2.33V22c4.78-.76 8.44-4.92 8.44-9.94Z',
  },
  {
    label: 'Instagram',
    href: 'https://instagram.com/procreal.ci',
    shapes: true,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/company/procreal',
    icon: 'M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.75C24 .78 23.2 0 22.22 0Z',
  },
  {
    label: 'YouTube',
    href: 'https://youtube.com/@procreal',
    icon: 'M23.5 6.19a2.94 2.94 0 0 0-2.07-2.08C19.7 3.6 12 3.6 12 3.6s-7.7 0-9.43.51A2.94 2.94 0 0 0 .5 6.19 30.6 30.6 0 0 0 0 12a30.6 30.6 0 0 0 .5 5.81 2.94 2.94 0 0 0 2.07 2.08c1.73.51 9.43.51 9.43.51s7.7 0 9.43-.51a2.94 2.94 0 0 0 2.07-2.08A30.6 30.6 0 0 0 24 12a30.6 30.6 0 0 0-.5-5.81ZM9.55 15.57V8.43L15.82 12Z',
  },
];
---
<footer class="bg-navy-dark text-white">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <Logo variant="dark" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-white/60">{t('footer.tagline')}</p>
      </div>

      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wide text-cyan">{t('footer.formationsTitle')}</h3>
        <ul class="mt-4 space-y-3 text-sm text-white/70">
          {formations.map((formation) => (
            <li>
              <a href={localizePath(`/formations/${formation.id}`, lang)} class="transition-colors hover:text-white">
                {localizedField(formation.data, 'title', lang)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wide text-cyan">{t('footer.usefulLinks')}</h3>
        <ul class="mt-4 space-y-3 text-sm text-white/70">
          {usefulLinks.map((link) => (
            <li>
              <a href={localizePath(link.href, lang)} class="transition-colors hover:text-white">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wide text-cyan">{t('footer.contactTitle')}</h3>
        <ul class="mt-4 space-y-3 text-sm text-white/70">
          <li>Cocody Faya, derrière Playce<br />Marché Diarrassouba, Abidjan</li>
          <li><a href="tel:+2250749817621" class="transition-colors hover:text-white">+225 07 49 81 76 21</a></li>
          <li><a href="mailto:procreal.r@gmail.com" class="transition-colors hover:text-white">procreal.r@gmail.com</a></li>
        </ul>
        <h3 class="mt-6 font-heading text-sm font-semibold uppercase tracking-wide text-cyan">{t('footer.followUs')}</h3>
        <div class="mt-3 flex gap-3">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-cyan"
            >
              {social.shapes ? (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="6" />
                  <circle cx="12" cy="12" r="4.7" />
                  <circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none" />
                </svg>
              ) : (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={social.icon} />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <p>
        &copy; {new Date().getFullYear()}{' '}
        <a href="https://www.webdesignmindset.com/" target="_blank" rel="noopener noreferrer" class="hover:text-white">
          Web Design Mindset
        </a>. {t('footer.rights')}
      </p>
      <div class="flex gap-5">
        <a href={localizePath('/mentions-legales', lang)} class="hover:text-white">{t('footer.legalMentions')}</a>
        <a href={localizePath('/politique-confidentialite', lang)} class="hover:text-white">{t('footer.privacyPolicy')}</a>
      </div>
    </div>
  </div>
</footer>
