---
import { localizePath } from '../i18n/utils';

const {
  lang,
  eyebrow,
  title,
  subtitle,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  image,
  scrollHint,
  variant = 'home',
} = Astro.props;
const isExternal = secondaryHref?.startsWith('http');
const isBridgeHero = variant === 'home';
---

<section class={`relative overflow-hidden bg-navy text-white ${variant === 'home' ? 'min-h-screen' : 'py-28 lg:py-36'}`} style="isolation:isolate;">
  {isBridgeHero ? (
    <>
      <div data-hero-bg class="absolute -inset-[2%] bg-cover will-change-transform" style="background-image:url('/img/bridge-cocody.jpg'); background-position:60% 42%; filter:brightness(0.65);"></div>
      <div class="absolute inset-0 bg-navy" style="mix-blend-mode:multiply; opacity:0.8;"></div>
      <div class="absolute inset-0" style="background:linear-gradient(125deg, #071c4a 0%, rgba(10,42,107,0.72) 38%, rgba(10,42,107,0.32) 60%, rgba(7,28,74,0.55) 100%);"></div>
      <div class="absolute inset-0" style="background:linear-gradient(to top, #071c4a 0%, rgba(7,28,74,0.7) 22%, rgba(7,28,74,0.1) 52%);"></div>
      <canvas data-hero-canvas class="absolute inset-0 hidden h-full w-full pointer-events-none md:block" style="mix-blend-mode:screen;"></canvas>
      <div class="absolute inset-0 pointer-events-none" style="box-shadow:inset 0 0 220px 40px rgba(7,28,74,0.7);"></div>
      <div data-hero-sheen class="absolute inset-y-0 left-0 w-[34%] pointer-events-none" style="background:linear-gradient(100deg, rgba(61,169,224,0) 0%, rgba(155,214,245,0.10) 50%, rgba(61,169,224,0) 100%);"></div>
    </>
  ) : (
    <div class="absolute inset-0">
      {image && <img src={image} alt="" class="h-full w-full object-cover opacity-30" />}
      <div class="absolute inset-0 bg-gradient-to-br from-navy via-navy/95 to-navy-dark"></div>
    </div>
  )}
  <div
    class={`relative z-[2] mx-auto flex max-w-5xl flex-col items-center px-5 text-center lg:px-8 ${
      variant === 'home' ? 'min-h-screen justify-center pt-24' : ''
    }`}
  >
    {eyebrow && (
      <p class="inline-flex items-center gap-2.5 text-sm font-semibold uppercase tracking-wide text-[#7FD0F2]">
        <span class="inline-block h-px w-6 bg-yellow"></span>
        {eyebrow}
        <span class="inline-block h-px w-6 bg-yellow"></span>
      </p>
    )}
    <h1 data-hero-split class="mt-3 font-heading text-4xl font-bold leading-[1.1] balance lg:text-6xl">{title}</h1>
    {subtitle && <p class="mx-auto mt-5 max-w-2xl text-white/70 lg:text-lg">{subtitle}</p>}
    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      {primaryHref && (
        <a
          href={localizePath(primaryHref, lang)}
          class="rounded-full bg-cyan px-7 py-3.5 font-semibold text-white transition-transform hover:scale-105"
        >
          {primaryLabel}
        </a>
      )}
      {secondaryHref && (
        <a
          href={secondaryHref}
          target={isExternal ? '_blank' : undefined}
          rel={isExternal ? 'noopener noreferrer' : undefined}
          class="rounded-full border border-white/30 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
        >
          {secondaryLabel}
        </a>
      )}
    </div>
    {isBridgeHero && (
      <div class="absolute bottom-7 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 text-[11px] uppercase tracking-[0.18em] text-white/55">
        <span>{scrollHint || (lang === 'en' ? 'Discover' : 'Découvrir')}</span>
        <span class="block h-8 w-px" style="background:linear-gradient(to bottom, rgba(245,197,24,0.9), rgba(245,197,24,0));"></span>
      </div>
    )}
  </div>
</section>
