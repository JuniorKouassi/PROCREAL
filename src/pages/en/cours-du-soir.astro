---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Accordion from '../../components/Accordion.astro';
import CTASection from '../../components/CTASection.astro';
import { courseSchema } from '../../lib/seo';
import { localizePath, useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const entry = await getEntry('formations', 'cours-du-soir');
const data = entry.data;

const moduleDescriptions = {
  'Understanding architectural drawing': 'Reading plans, representation standards and the basics of hand technical drawing before going digital.',
  AutoCAD: 'Full hands-on training on AutoCAD to produce precise, standardized 2D plans.',
  ArchiCAD: 'Moving to the 3D digital model: walls, slabs, roofs, joinery and automatic documentation.',
};
function moduleTopic(label) {
  const parts = label.split('—');
  return parts[parts.length - 1].trim();
}
const moduleItems = data.modules_en.map((label) => ({
  title: label,
  content: moduleDescriptions[moduleTopic(label)] || 'Guided learning and hands-on coaching on this module.',
}));

const whatsappHref = `https://wa.me/2250749817621?text=${encodeURIComponent("Hello PROcréal, I'd like information about the Evening Classes.")}`;
const registerHref = `${localizePath('/inscription', lang)}?formation=cours-du-soir`;
---

<BaseLayout
  title="Evening Classes — Drafting & CAD in Abidjan"
  description="Architecture night classes in Abidjan: 70 hours, 3 evenings a week, to go from hand-drawing to AutoCAD and ArchiCAD without leaving your job."
  jsonLd={[courseSchema(data, lang, '/en/cours-du-soir')]}
>
  <Hero
    lang={lang}
    variant="formation"
    eyebrow="Flagship course"
    title="Evening Classes — Drafting & CAD"
    subtitle="Three evenings a week, go from hand-drawing to AutoCAD and ArchiCAD mastery without leaving your day job."
    primaryLabel={t('cta.registerNow')}
    primaryHref={registerHref}
    secondaryLabel={t('cta.whatsapp')}
    secondaryHref={whatsappHref}
  />

  <section class="bg-white py-20">
    <div class="mx-auto max-w-3xl px-5 text-center lg:px-8">
      <p class="reveal text-sm font-semibold uppercase tracking-wide text-cyan">The promise</p>
      <h2 class="reveal mt-3 font-heading text-3xl font-bold text-navy balance lg:text-4xl">
        Solid CAD skills, without pausing your career
      </h2>
      <p class="reveal mt-5 leading-relaxed text-muted">
        Designed for busy schedules, this three-module path takes you from paper sketch to a complete technical
        file — evening after evening, without sacrificing your job or studies.
      </p>
    </div>
  </section>

  <section class="bg-cream py-20">
    <div class="mx-auto max-w-4xl px-5 lg:px-8">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-cyan">{t('common.modules')}</p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-navy balance lg:text-4xl">The 3 modules</h2>
      </div>
      <div class="mt-12">
        <Accordion items={moduleItems} />
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-5 lg:px-8">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-cyan">{t('common.schedule')}</p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-navy balance lg:text-4xl">Session schedule</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { label: t('common.schedule'), value: data.schedule_en },
          { label: t('common.duration'), value: data.duration_en },
          { label: t('common.nextSession'), value: new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(data.startDate)) },
          { label: t('common.location'), value: data.location_en },
        ].map((item) => (
          <div class="reveal rounded-2xl bg-cream p-6 text-center">
            <p class="text-xs font-semibold uppercase tracking-wide text-muted">{item.label}</p>
            <p class="mt-2 font-heading text-sm font-bold text-navy">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy py-20 text-white">
    <div class="mx-auto max-w-3xl px-5 text-center lg:px-8">
      <p class="reveal text-sm font-semibold uppercase tracking-wide text-cyan">{t('common.price')}</p>
      <h2 class="reveal mt-3 font-heading text-4xl font-bold lg:text-5xl">
        {data.price.toLocaleString('en-US')} {data.currency}
      </h2>
      <p class="reveal mt-2 text-white/70">
        + {data.registration.toLocaleString('en-US')} {data.currency} {t('common.registrationFee').toLowerCase()}
      </p>
      <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={registerHref} class="rounded-full bg-cyan px-7 py-3.5 font-semibold text-white transition-transform hover:scale-105">
          {t('cta.registerNow')}
        </a>
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="rounded-full border border-white/30 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-white/10">
          {t('cta.whatsapp')}
        </a>
      </div>
    </div>
  </section>

  <CTASection
    lang={lang}
    title="Next session starts May 6, 2026"
    subtitle="Seats are limited to guarantee individual follow-up. Enrol now."
    primaryLabel={t('cta.registerNow')}
    primaryHref={registerHref}
    secondaryLabel={t('cta.viewDetails')}
    secondaryHref={localizePath('/formations/cours-du-soir', lang)}
  />
</BaseLayout>
