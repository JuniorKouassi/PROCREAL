---
const { items = [] } = Astro.props;
---

<div class="reveal divide-y divide-navy/10 rounded-2xl bg-white shadow-sm ring-1 ring-navy/5">
  {items.map((item) => (
    <details class="group p-6">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-heading font-semibold text-navy">
        <span>{item.title}</span>
        <svg class="h-5 w-5 shrink-0 text-cyan transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none">
          <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </summary>
      <p class="mt-3 text-sm leading-relaxed text-muted">{item.content}</p>
    </details>
  ))}
</div>
