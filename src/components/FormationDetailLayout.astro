---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from './Hero.astro';
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/utils';
import { courseSchema, breadcrumbSchema } from '../lib/seo';

const { formation, path, title, description, image, infoItems = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const jsonLd = [
  courseSchema(formation, lang, path),
  breadcrumbSchema([
    { name: lang === 'en' ? 'Home' : 'Accueil', url: '/' },
    { name: t('nav.formations'), url: '/formations' },
    { name: title, url: path },
  ]),
];

const whatsappHref = `https://wa.me/2250749817621?text=${encodeURIComponent(t('whatsapp.default'))}`;
---

<BaseLayout title={title} description={description} image={image} jsonLd={jsonLd} bodyClass="pb-36 lg:pb-0">
  <Hero
    lang={lang}
    variant="formation"
    eyebrow={t('nav.formations')}
    title={title}
    subtitle={description}
    primaryLabel={t('cta.register')}
    primaryHref="/inscription"
    secondaryLabel={t('cta.whatsapp')}
    secondaryHref={whatsappHref}
  />

  <section class="relative z-10 -mt-10">
    <div class="reveal mx-auto max-w-5xl px-5 lg:px-8">
      <div class="grid grid-cols-2 gap-5 rounded-2xl bg-white p-6 shadow-lg shadow-navy/10 ring-1 ring-navy/5 sm:grid-cols-3 lg:grid-cols-6">
        {infoItems.map((item) => (
          <div class="text-center">
            <p class="text-xs font-semibold uppercase tracking-wide text-muted">{item.label}</p>
            <p class="mt-1 font-heading text-sm font-bold text-navy">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-5xl gap-10 px-5 py-16 lg:grid lg:grid-cols-[1fr_320px] lg:px-8">
    <div class="space-y-14">
      <slot />
    </div>
    <aside class="mt-12 lg:mt-0">
      <div class="lg:sticky lg:top-28">
        <slot name="sidebar" />
      </div>
    </aside>
  </div>

  <div data-mobile-cta class="fixed inset-x-0 bottom-16 z-40 flex gap-3 border-t border-navy/10 bg-white p-4 shadow-lg lg:hidden">
    <a href={localizePath('/inscription', lang)} class="flex-1 rounded-full bg-cyan px-5 py-3 text-center font-semibold text-white">
      {t('cta.registerNow')}
    </a>
  </div>
</BaseLayout>
